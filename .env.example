# Quant Strategy Desk — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# === Broker ===
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
# IBKR_ACCOUNT=

# === Data Sources ===
# EODHD_API_KEY=
# ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=                    # Required for Tier 1 macro snapshots (free at fred.stlouisfed.org)

# === Notifications ===
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# ALERT_EMAIL=

# === Database ===
DB_PATH=data/quant_desk.db
# POSTGRES_URL=

# === Trading Mode ===
TRADING_MODE=paper
# Options: paper, live
