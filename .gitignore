*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
eggs/
*.egg
.Python
pip-log.txt
pip-delete-this-directory.txt

# Virtual environment
venv/
.venv/
env/

# IDE
.vscode/
.idea/

# Data (large files — store externally)
**/*.db
**/*.sqlite
data/*.csv
data/*.parquet
!data/.gitkeep

# Jupyter
